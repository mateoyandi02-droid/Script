local lp = game:GetService("Players").LocalPlayer
local http = game:GetService("HttpService")

-- Fuerza la descarga fresca de la whitelist para evitar el caché
local WhitelistURL = "https://raw.githubusercontent.com/mateoyandi02-droid/Script/main/whitelist.json?nocache=" .. tick()

local function IsWhitelisted()
    local success, response = pcall(function()
        return game:HttpGet(WhitelistURL)
    end)

    if success then
        local data = http:JSONDecode(response)
        if data[tostring(lp.UserId)] == true then
            return true
        end
    end
    return false
end

-- BLOQUEO CRÍTICO: Si no está en la lista, se acaba todo.
if not IsWhitelisted() then
    lp:Kick("🚫 ACUSADO HUB: TU ID (" .. lp.UserId .. ") NO TIENE ACCESO. CONTACTA A @acusado_sb")
    error("ACCESO DENEGADO") -- Detiene el script por completo
    return
end

