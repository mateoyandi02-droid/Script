-- [[ ACUSADO NINJA HUB MASHMELLOW - ACUSADO DOMINA EDITION ]] --
-- SEGURIDAD: WHITELIST ONLINE | LÓGICA: AUTOFARM MASHMELLOW

local lp = game:GetService("Players").LocalPlayer
local http = game:GetService("HttpService")

-- [ 1. SISTEMA DE SEGURIDAD (WHITELIST) ]
-- Usamos tu archivo con el punto al inicio: .Whitelist.json
local WhitelistURL = "https://raw.githubusercontent.com/mateoyandi02-droid/Script/main/.Whitelist.json?nocache=" .. tick()

local function CheckAccess()
    local success, response = pcall(function()
        return game:HttpGet(WhitelistURL)
    end)

    if success then
        local decodeSuccess, data = pcall(function() return http:JSONDecode(response) end)
        if decodeSuccess and data[tostring(lp.UserId)] == true then
            return true
        end
    end
    return false
end

-- Bloqueo inmediato si no está autorizado
if not CheckAccess() then
    lp:Kick("\n[ACUSADO HUB]\nTU ID: " .. lp.UserId .. "\nNO TIENE ACCESO.\nContacta a @acusado_sb")
    return
end

-- [ 2. CONFIGURACIÓN Y SERVICIOS ]
